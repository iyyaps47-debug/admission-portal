# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your actual Google Form values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# The "action" URL for your Google Form (ends with /formResponse)
# Example: https://docs.google.com/forms/d/e/YOUR_FORM_ID/formResponse
GOOGLE_FORM_ACTION_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID_HERE/formResponse

# Entry IDs for each question in your Google Form.
# Find these by inspecting the pre-filled link. They look like: entry.123456789
GOOGLE_FORM_NAME_FIELD=entry.000000001
GOOGLE_FORM_PHONE_FIELD=entry.000000002
GOOGLE_FORM_EMAIL_FIELD=entry.000000003
GOOGLE_FORM_STATUS_FIELD=entry.000000004
GOOGLE_FORM_COURSE_FIELD=entry.000000005
